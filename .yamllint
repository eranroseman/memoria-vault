# Lints the authored YAML: workspace/runtime config, GitHub workflows, and issue
# templates. These configs are load-bearing — a bad indent or duplicate key
# breaks the runtime or CI.
#
# Relaxed: flag real problems (syntax, duplicate keys, bad indentation, trailing
# spaces, mis-nested blocks) but not line length — many config lines are long by
# design.
#
# Never lint vendored or scratch areas: any `.obsidian/` holds vendored plugin
# files, and `.notes/` / `test-vault/` are local gitignored scratch. This guards a
# bare `yamllint .` too — the CI/hook invocations additionally scope to tracked,
# non-.obsidian YAML.
extends: relaxed
ignore: |
  **/.obsidian/
  .notes/
  test-vault/
rules:
  line-length: disable
  colons: disable   # values are intentionally column-aligned (e.g. tool-registry.yaml)
