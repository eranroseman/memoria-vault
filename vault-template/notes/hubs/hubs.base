# Hub notes by topic.
filters:
  and:
    - file.inFolder("notes/hubs")
    - 'lifecycle != "archived"'
    - 'sample != true'
formulas:
  note: 'link(file.path, title)'
properties:
  formula.note:
    displayName: "Note"
views:
  - type: table
    name: "Hubs index"
    order:
      - formula.note
      - lifecycle
      - topic
      - members
