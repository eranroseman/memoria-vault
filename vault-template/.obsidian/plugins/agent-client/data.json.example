{
  "_comment": "Example agent-client config. The production Windows path calls native hermes on PATH. After first launch, the plugin appends savedSessions[] \u2014 that's normal and safe to commit. See https://github.com/eranroseman/memoria-vault/blob/main/docs/how-to-guides/using-obsidian/use-the-acp-pane.md",
  "_customAgents_note": "Memoria configures ONE interactive agent \u2014 the Co-PI (ADR-48): the only agent the PI converses with. It questions (the old Socratic role), explains the system, and DELEGATES tasks to the background lanes (Librarian, Writer, Peer-reviewer, Engineer) via the tasks MCP \u2014 those lanes run on Kanban dispatch, never in this pane. See https://github.com/eranroseman/memoria-vault/blob/main/docs/how-to-guides/using-obsidian/use-the-acp-pane.md",
  "customAgents": [
    {
      "id": "memoria-copi",
      "displayName": "Memoria Co-PI",
      "command": "hermes",
      "args": [
        "-p",
        "memoria-copi",
        "acp"
      ],
      "env": []
    }
  ],
  "defaultAgentId": "memoria-copi",
  "autoAllowPermissions": false,
  "autoMentionActiveNote": true,
  "enableSystemNotifications": true,
  "debugMode": false,
  "nodePath": "",
  "_exportSettings_note": "Session exports are visible raw material: they land in system/exports/ for PI review. Do NOT point exports at inbox/ (agent-raised honesty cards only), projects/ (reserved), or .memoria/ (hidden runtime internals).",
  "exportSettings": {
    "defaultFolder": "system/exports",
    "filenameTemplate": "chat_{date}_{time}",
    "autoExportOnNewChat": true,
    "autoExportOnCloseChat": true,
    "openFileAfterExport": false,
    "includeImages": true,
    "imageLocation": "obsidian",
    "imageCustomFolder": "system/exports/assets",
    "frontmatterTag": "agent-client"
  },
  "_wsl_note": "Production Windows uses native hermes with windowsWslMode false. Set true only for the Linux/WSL test path where Obsidian is on Windows but hermes is inside WSL.",
  "windowsWslMode": false,
  "sendMessageShortcut": "enter",
  "chatViewLocation": "right-tab",
  "displaySettings": {
    "autoCollapseDiffs": false,
    "diffCollapseThreshold": 10,
    "maxNoteLength": 10000,
    "maxSelectionLength": 10000,
    "showEmojis": true,
    "fontSize": null
  },
  "_savedSessions_note": "After first launch the plugin appends savedSessions[] for the Co-PI pane \u2014 normal and safe to commit.",
  "savedSessions": [],
  "lastUsedModels": {},
  "lastUsedModes": {},
  "enableFloatingChat": false,
  "floatingButtonImage": "",
  "floatingWindowSize": {
    "width": 400,
    "height": 500
  },
  "floatingWindowPosition": null,
  "floatingButtonPosition": null
}
