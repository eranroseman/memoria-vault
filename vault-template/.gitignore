# Obsidian per-machine state — different per device, regenerated on use
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Files holding secrets or per-machine data. Each is gitignored and ships as a
# sanitized example sibling that the human copies and fills in locally.
# Convention: a new secret-bearing file gets BOTH a line here AND an example.
# Memoria-authored examples use lowercase `.example` (industry standard); the
# Hermes-generated `.env.EXAMPLE` is uppercase (upstream tooling — not changed).

# Obsidian Local REST API plugin: data.json contains generated secrets
# (apiKey, TLS certificate, RSA private key). Plugin regenerates on first launch.
# Only the data.json.example file ships in this repo.
.obsidian/plugins/obsidian-local-rest-api/data.json

# agent-client: data.json holds per-machine agent command paths ({{HOME}}) and
# any provider apiKeys. Ships as data.json.example.
.obsidian/plugins/agent-client/data.json

# Librarian project hints: personal project scopes / topic lists (ADR-15).
# Ships as project-hints.yaml.example.
.memoria/project-hints.yaml

# Per-machine secret material (human copies .env.EXAMPLE to .env, fills in keys)
.env

# Python bytecode (profile detector scripts)
__pycache__/
*.pyc

# MCP server dependencies live in a vault-local venv the installer creates
# (.memoria/.venv). Per-machine, regenerable, never committed.
.memoria/.venv/

# Runtime SQLite state is local working state. Durable machine-readable outputs
# are replayable from requests, journals, blobs, and checked Concepts.
.memoria/memoria.sqlite
.memoria/memoria.sqlite-*

# Runtime product/config mirrors. The package and SQLite journal are authority;
# workspace commits carry only the checked corpus and the journal-head anchor.
.memoria/config/
.memoria/locks/
.memoria/schemas/
journal/

# Alpha.12 worker holding areas: runtime content is disposable, the skeleton
# .gitkeep files are tracked so fresh installs create the directories.
.memoria/index/**
!.memoria/index/
!.memoria/index/qmd/
!.memoria/index/qmd/.gitkeep
.memoria/staging/**
!.memoria/staging/
!.memoria/staging/*/
!.memoria/staging/*/.gitkeep
.memoria/quarantine/**
!.memoria/quarantine/
!.memoria/quarantine/.gitkeep
.memoria/queue/**
!.memoria/queue/
!.memoria/queue/*/
!.memoria/queue/*/.gitkeep
.memoria/state/**
!.memoria/state/
!.memoria/state/.gitkeep
.memoria/blobs/provider-payloads/**
!.memoria/blobs/provider-payloads/
!.memoria/blobs/provider-payloads/.gitkeep
.memoria/blobs/source-content/**
!.memoria/blobs/source-content/
!.memoria/blobs/source-content/.gitkeep

# Captured source blobs are referenced from source Concepts and synced out of band.
catalog/sources/*/raw/

# Downloaded reference datasets refreshed on a cron (e.g. the Retraction Watch
# CSV pulled by operations/integrity/retraction/retraction.py --refresh). Large, regenerable,
# not source — never committed.
.memoria/data/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor scratch / sync conflict artifacts
*.tmp.*
*.bak
*.swp
*~
.#*
*.orig
*.rej
