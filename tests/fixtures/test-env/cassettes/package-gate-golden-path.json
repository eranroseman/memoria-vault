{
  "schema_version": 1,
  "name": "package-gate-golden-path",
  "description": "Model-free package-gate cassette: checked project notes -> argument canvas, plus the deny assertion.",
  "match": "tool_name+arg_shape",
  "gates": ["source", "package"],
  "steps": [
    {
      "id": "seed-project",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str",
        "verdict": "str"
      },
      "args": {
        "path": "knowledge/projects/harness.md",
        "verdict": "checked",
        "content": "---\ntype: project\nid: 01ARZ3NDEKTSV4RRFFQ69G5FC0\ntags: []\nlinks: {}\ntitle: Harness project\ndescription: Package-gate alpha.15 project.\nthesis: knowledge/notes/harness-thesis.md\n---\n\n# Harness project\n"
      },
      "expect": {
        "writes": ["knowledge/projects/harness.md"]
      }
    },
    {
      "id": "seed-thesis",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str",
        "verdict": "str"
      },
      "args": {
        "path": "knowledge/notes/harness-thesis.md",
        "verdict": "checked",
        "content": "---\ntype: note\nid: 01ARZ3NDEKTSV4RRFFQ69G5FC1\ntags: []\nlinks: {}\ntitle: Harness thesis\n---\n\nHarnessed workflows make durable research systems testable.\n"
      },
      "expect": {
        "writes": ["knowledge/notes/harness-thesis.md"]
      }
    },
    {
      "id": "seed-supporting-note",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str",
        "verdict": "str"
      },
      "args": {
        "path": "knowledge/notes/harness-support.md",
        "verdict": "checked",
        "content": "---\ntype: note\nid: 01ARZ3NDEKTSV4RRFFQ69G5FC2\ntags: []\ntitle: Harness support\nlinks:\n  supports:\n    - knowledge/notes/harness-thesis.md\n---\n\nHarnessed workflows support the project thesis.\n"
      },
      "expect": {
        "writes": ["knowledge/notes/harness-support.md"]
      }
    },
    {
      "id": "seed-refuting-note",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str",
        "verdict": "str"
      },
      "args": {
        "path": "knowledge/notes/harness-refutation.md",
        "verdict": "checked",
        "content": "---\ntype: note\nid: 01ARZ3NDEKTSV4RRFFQ69G5FC3\ntags: []\ntitle: Harness refutation\nlinks:\n  contradicts:\n    - knowledge/notes/harness-thesis.md\n---\n\nSparse fixtures can miss live-runtime failures.\n"
      },
      "expect": {
        "writes": ["knowledge/notes/harness-refutation.md"]
      }
    },
    {
      "id": "discuss-gap",
      "tool": "inbox.write_proposal",
      "arg_shape": {
        "action": "str",
        "argument_against": "str",
        "argument_for": "str",
        "card_type": "str",
        "certainty": "str",
        "raised_by": "str",
        "title": "str",
        "what_tipped_it": "str"
      },
      "args": {
        "card_type": "gap",
        "title": "Harness discussion gap",
        "action": "Discuss whether the cassette covers the project handoff path.",
        "argument_for": "The cassette exercises real deterministic operations.",
        "argument_against": "It does not judge live model quality.",
        "what_tipped_it": "ADR-80 Phase 1 draws the line at model-free package-gate wiring.",
        "certainty": "likely",
        "raised_by": "test-env-harness"
      },
      "expect": {
        "writes_prefix": ["inbox/gap-harness-discussion-gap"]
      }
    },
    {
      "id": "project-canvas",
      "tool": "project.argument_canvas",
      "arg_shape": {
        "project": "str"
      },
      "args": {
        "project": "harness"
      },
      "expect": {
        "writes": ["knowledge/projects/harness/argument.canvas"]
      }
    },
    {
      "id": "done-prompt",
      "tool": "inbox.write_work_prompt",
      "arg_shape": {
        "action": "str",
        "posture": "str",
        "raised_by": "str",
        "request_id": "str",
        "target": "str",
        "title": "str",
        "what_happened": "str"
      },
      "args": {
        "title": "Review harness argument canvas",
        "action": "Review the cassette-backed source, notes, and argument canvas.",
        "what_happened": "The model-free package-gate harness replay reached the project handoff.",
        "target": "knowledge/projects/harness/argument.canvas",
        "request_id": "HARNESS-PACKAGE",
        "posture": "writer",
        "raised_by": "test-env-harness"
      },
      "expect": {
        "writes_prefix": ["inbox/work-prompt-review-harness-argument-canvas"]
      }
    }
  ],
  "final_assertions": {
    "exists": [
      "knowledge/projects/harness.md",
      "knowledge/notes/harness-thesis.md",
      "knowledge/notes/harness-support.md",
      "knowledge/notes/harness-refutation.md",
      "knowledge/projects/harness/argument.canvas"
    ],
    "not_exists": ["knowledge/notes/blocked-by-harness.md"]
  }
}
