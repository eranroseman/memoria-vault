{
  "schema_version": 1,
  "name": "package-gate-golden-path",
  "description": "Model-free alpha.11 package-gate cassette: source -> classify -> checked project notes -> argument canvas, plus the deny assertion.",
  "match": "tool_name+arg_shape",
  "gates": ["source", "package"],
  "steps": [
    {
      "id": "ingest-source",
      "tool": "ingest.paper",
      "arg_shape": {
        "bibtex": "str",
        "citekey": "str"
      },
      "args": {
        "citekey": "harness2026",
        "bibtex": "@article{harness2026,\n  title = {Harnessed Workflows for Durable Research},\n  author = {Ada, River and Lin, Morgan},\n  year = {2026},\n  journal = {Journal of Testable Systems},\n  doi = {10.1000/harness.2026},\n  abstract = {A fixture paper for the Memoria test environment harness.}\n}\n"
      },
      "expect": {
        "writes": ["catalog/sources/harness2026/source.md"]
      }
    },
    {
      "id": "classify-source",
      "tool": "classify.apply",
      "arg_shape": {
        "citekey": "str",
        "merged": {
          "publication_types": ["str"],
          "topics_scored": [
            {
              "name": "str",
              "score": "float",
              "subfield": "str"
            }
          ]
        }
      },
      "args": {
        "citekey": "harness2026",
        "merged": {
          "topics_scored": [
            {
              "name": "Research software engineering",
              "subfield": "software engineering",
              "score": 0.91
            },
            {
              "name": "Knowledge management",
              "subfield": "information systems",
              "score": 0.61
            }
          ],
          "publication_types": ["review"]
        }
      },
      "expect": {
        "writes": ["system/logs/classify.jsonl"]
      }
    },
    {
      "id": "seed-project",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str"
      },
      "args": {
        "path": "knowledge/projects/harness.md",
        "content": "---\ntype: project\ncheck_status: checked\ntitle: Harness project\ndescription: Package-gate alpha.11 project.\nthesis: knowledge/notes/harness-thesis.md\n---\n\n# Harness project\n"
      },
      "expect": {
        "writes": ["knowledge/projects/harness.md"]
      }
    },
    {
      "id": "seed-thesis",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str"
      },
      "args": {
        "path": "knowledge/notes/harness-thesis.md",
        "content": "---\ntype: note\ncheck_status: checked\ntitle: Harness thesis\nstatus: accepted\nevidence_set: [catalog/sources/harness2026/source.md]\n---\n\nHarnessed workflows make durable research systems testable.\n"
      },
      "expect": {
        "writes": ["knowledge/notes/harness-thesis.md"]
      }
    },
    {
      "id": "seed-supporting-note",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str"
      },
      "args": {
        "path": "knowledge/notes/harness-support.md",
        "content": "---\ntype: note\ncheck_status: checked\ntitle: Harness support\nstatus: accepted\nevidence_set: [catalog/sources/harness2026/source.md]\nlinks:\n  supports:\n    - knowledge/notes/harness-thesis.md\n---\n\nHarnessed workflows support the project thesis.\n"
      },
      "expect": {
        "writes": ["knowledge/notes/harness-support.md"]
      }
    },
    {
      "id": "seed-refuting-note",
      "tool": "vault.write_markdown",
      "arg_shape": {
        "content": "str",
        "path": "str"
      },
      "args": {
        "path": "knowledge/notes/harness-refutation.md",
        "content": "---\ntype: note\ncheck_status: checked\ntitle: Harness refutation\nstatus: accepted\nevidence_set: [catalog/sources/harness2026/source.md]\nlinks:\n  contradicts:\n    - knowledge/notes/harness-thesis.md\n---\n\nSparse fixtures can miss live-runtime failures.\n"
      },
      "expect": {
        "writes": ["knowledge/notes/harness-refutation.md"]
      }
    },
    {
      "id": "discuss-gap",
      "tool": "inbox.write_proposal",
      "arg_shape": {
        "action": "str",
        "argument_against": "str",
        "argument_for": "str",
        "card_type": "str",
        "certainty": "str",
        "raised_by": "str",
        "title": "str",
        "what_tipped_it": "str"
      },
      "args": {
        "card_type": "gap",
        "title": "Harness discussion gap",
        "action": "Discuss whether the cassette covers the deterministic path.",
        "argument_for": "The cassette exercises real deterministic operations.",
        "argument_against": "It does not judge live model quality.",
        "what_tipped_it": "ADR-80 Phase 1 draws the line at model-free package-gate wiring.",
        "certainty": "likely",
        "raised_by": "test-env-harness"
      },
      "expect": {
        "writes_prefix": ["inbox/gap-harness-discussion-gap"]
      }
    },
    {
      "id": "project-canvas",
      "tool": "project.argument_canvas",
      "arg_shape": {
        "project": "str"
      },
      "args": {
        "project": "harness"
      },
      "expect": {
        "writes": ["knowledge/projects/harness/argument.canvas"]
      }
    },
    {
      "id": "deny-assertion",
      "tool": "policy.deny_assertion",
      "arg_shape": {
        "content": "str",
        "path": "str",
        "profile": "str",
        "task_id": "str",
        "tool_name": "str"
      },
      "args": {
        "profile": "memoria-writer",
        "tool_name": "mcp_obsidian_vault_write",
        "path": "knowledge/notes/blocked-by-harness.md",
        "content": "must not land",
        "task_id": "HARNESS-DENY"
      },
      "expect": {
        "audit_decision": "deny",
        "not_exists": ["knowledge/notes/blocked-by-harness.md"]
      }
    },
    {
      "id": "done-prompt",
      "tool": "inbox.write_work_prompt",
      "arg_shape": {
        "action": "str",
        "lane": "str",
        "raised_by": "str",
        "target": "str",
        "task_id": "str",
        "title": "str",
        "what_happened": "str"
      },
      "args": {
        "title": "Review harness argument canvas",
        "action": "Review the cassette-backed source, notes, and argument canvas.",
        "what_happened": "The model-free package-gate harness replay reached the alpha.11 handoff.",
        "target": "knowledge/projects/harness/argument.canvas",
        "task_id": "HARNESS-PACKAGE",
        "lane": "memoria-writer",
        "raised_by": "test-env-harness"
      },
      "expect": {
        "writes_prefix": ["inbox/work-prompt-review-harness-argument-canvas"]
      }
    }
  ],
  "final_assertions": {
    "exists": [
      "catalog/sources/harness2026/source.md",
      "system/logs/classify.jsonl",
      "knowledge/projects/harness.md",
      "knowledge/notes/harness-thesis.md",
      "knowledge/notes/harness-support.md",
      "knowledge/notes/harness-refutation.md",
      "knowledge/projects/harness/argument.canvas",
      "system/logs/audit.jsonl"
    ],
    "not_exists": ["knowledge/notes/blocked-by-harness.md"]
  }
}
