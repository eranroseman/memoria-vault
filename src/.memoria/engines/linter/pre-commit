#!/usr/bin/env bash
# pre-commit — the Linter's write-time gate (ADR-49 / D50).
#
# Gates git-tracked vault writes at commit: every STAGED .md note must pass
# lint:check-schema against .memoria/schemas/. Live in-app edits are caught by
# the cron sweep; this hook is the "gates at commit, monitors between" half.
# The installer wires it into the deployed vault's .git/hooks/pre-commit (ADR-55).
set -euo pipefail

VAULT_ROOT="$(git rev-parse --show-toplevel)"
ENGINE="$VAULT_ROOT/.memoria/engines/linter/precommit_check.py"
[ -f "$ENGINE" ] || exit 0   # not a Memoria vault checkout — no gate

staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' || true)
[ -n "$staged" ] || exit 0

# shellcheck disable=SC2086
exec python3 "$ENGINE" --vault "$VAULT_ROOT" $staged
