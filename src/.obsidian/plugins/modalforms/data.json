{
  "editorPosition": "right",
  "attachShortcutToGlobalWindow": false,
  "globalNamespace": "MF",
  "formDefinitions": [
    {
      "title": "Memoria source capture",
      "name": "memoria-source-capture",
      "version": "1",
      "fields": [
        {
          "name": "title",
          "label": "Source title",
          "description": "Title for the proposed source note.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "entity",
          "label": "Catalog entity",
          "description": "Wikilink target for the catalog entity this source is about.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "source_type",
          "label": "Source type",
          "description": "Kind of source being captured.",
          "isRequired": true,
          "input": {
            "type": "select",
            "source": "fixed",
            "options": [
              {
                "label": "Paper",
                "value": "paper"
              },
              {
                "label": "Dataset",
                "value": "dataset"
              },
              {
                "label": "Repository",
                "value": "repository"
              },
              {
                "label": "Web page",
                "value": "web-page"
              },
              {
                "label": "Report",
                "value": "report"
              }
            ]
          }
        },
        {
          "name": "research_area",
          "label": "Research area",
          "description": "Controlled terms from system/vocabulary.md.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "options": [
              "personal-informatics",
              "mobile-health",
              "digital-mental-health",
              "health-equity",
              "patient-clinician-communication",
              "engagement-sustained-use",
              "chronic-disease-management",
              "behavior-change",
              "llm-generative-ai-for-health",
              "patient-generated-data",
              "family-caregiver-health",
              "mobile-sensing",
              "sociotechnical-systems",
              "social-computing-for-health",
              "conversational-agents",
              "community-health",
              "digital-therapeutics",
              "wearable-sensing",
              "aging",
              "human-ai-interaction",
              "online-health-communities",
              "implementation-science",
              "sensemaking",
              "race-intersectionality",
              "cscw-collaborative-work",
              "jitai",
              "ema-self-report"
            ]
          }
        },
        {
          "name": "methodology",
          "label": "Methodology",
          "description": "Controlled terms from system/vocabulary.md.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "options": [
              "rct",
              "quasi-experiment",
              "observational",
              "field-study",
              "lab-experiment",
              "survey-study",
              "qualitative",
              "design-science",
              "formative-study",
              "case-study",
              "systematic-review",
              "meta-analysis",
              "secondary-analysis",
              "semi-structured-interview",
              "thematic-analysis",
              "grounded-theory",
              "contextual-inquiry",
              "experience-sampling",
              "ecological-momentary-assessment",
              "diary-study",
              "co-design",
              "usability-testing",
              "think-aloud",
              "survey",
              "regression",
              "mixed-effects-model",
              "log-analysis",
              "machine-learning",
              "nlp",
              "content-analysis",
              "participant-observation",
              "ab-test"
            ]
          }
        },
        {
          "name": "summary",
          "label": "In my words",
          "description": "Short PI-authored summary for the source note body.",
          "input": {
            "type": "textarea"
          }
        }
      ]
    }
  ]
}
