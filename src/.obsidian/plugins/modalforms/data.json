{
  "editorPosition": "right",
  "attachShortcutToGlobalWindow": false,
  "globalNamespace": "MF",
  "formDefinitions": [
    {
      "title": "Memoria source capture",
      "name": "memoria-source-capture",
      "version": "1",
      "fields": [
        {
          "name": "title",
          "label": "Source title",
          "description": "Title for the proposed source note.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "entity",
          "label": "Catalog entity",
          "description": "Wikilink target for the catalog entity this source is about.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "source_type",
          "label": "Source type",
          "description": "Kind of source being captured.",
          "isRequired": true,
          "input": {
            "type": "select",
            "source": "fixed",
            "options": [
              {
                "label": "Paper",
                "value": "paper"
              },
              {
                "label": "Dataset",
                "value": "dataset"
              },
              {
                "label": "Repository",
                "value": "repository"
              },
              {
                "label": "Web page",
                "value": "web-page"
              },
              {
                "label": "Report",
                "value": "report"
              }
            ]
          }
        },
        {
          "name": "research_area",
          "label": "Research area",
          "description": "Controlled terms from system/vocabulary.md.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "multi_select_options": [
              "personal-informatics",
              "mobile-health",
              "digital-mental-health",
              "health-equity",
              "patient-clinician-communication",
              "engagement-sustained-use",
              "chronic-disease-management",
              "behavior-change",
              "llm-generative-ai-for-health",
              "patient-generated-data",
              "family-caregiver-health",
              "mobile-sensing",
              "sociotechnical-systems",
              "social-computing-for-health",
              "conversational-agents",
              "community-health",
              "digital-therapeutics",
              "wearable-sensing",
              "aging",
              "human-ai-interaction",
              "online-health-communities",
              "implementation-science",
              "sensemaking",
              "race-intersectionality",
              "cscw-collaborative-work",
              "jitai",
              "ema-self-report"
            ]
          }
        },
        {
          "name": "methodology",
          "label": "Methodology",
          "description": "Controlled terms from system/vocabulary.md.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "multi_select_options": [
              "rct",
              "quasi-experiment",
              "observational",
              "field-study",
              "lab-experiment",
              "survey-study",
              "qualitative",
              "design-science",
              "formative-study",
              "case-study",
              "systematic-review",
              "meta-analysis",
              "secondary-analysis",
              "semi-structured-interview",
              "thematic-analysis",
              "grounded-theory",
              "contextual-inquiry",
              "experience-sampling",
              "ecological-momentary-assessment",
              "diary-study",
              "co-design",
              "usability-testing",
              "think-aloud",
              "survey",
              "regression",
              "mixed-effects-model",
              "log-analysis",
              "machine-learning",
              "nlp",
              "content-analysis",
              "participant-observation",
              "ab-test"
            ]
          }
        },
        {
          "name": "summary",
          "label": "In my words",
          "description": "Short PI-authored summary for the source note body.",
          "input": {
            "type": "textarea"
          }
        }
      ]
    },
    {
      "title": "Memoria project start",
      "name": "memoria-project-start",
      "version": "1",
      "fields": [
        {
          "name": "title",
          "label": "Project title",
          "description": "Human-readable project name.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "slug",
          "label": "Project slug",
          "description": "Folder-safe slug for the future project workspace.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "scope_topics",
          "label": "Scope topics",
          "description": "Controlled topic terms that bound the project map.",
          "isRequired": true,
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "multi_select_options": [
              "personal-informatics",
              "mobile-health",
              "digital-mental-health",
              "health-equity",
              "patient-clinician-communication",
              "engagement-sustained-use",
              "chronic-disease-management",
              "behavior-change",
              "llm-generative-ai-for-health",
              "patient-generated-data",
              "family-caregiver-health",
              "mobile-sensing",
              "sociotechnical-systems",
              "social-computing-for-health",
              "conversational-agents",
              "community-health",
              "digital-therapeutics",
              "wearable-sensing",
              "aging",
              "human-ai-interaction",
              "online-health-communities",
              "implementation-science",
              "sensemaking",
              "race-intersectionality",
              "cscw-collaborative-work",
              "jitai",
              "ema-self-report"
            ]
          }
        },
        {
          "name": "inquiry_population",
          "label": "Population",
          "description": "Who or what the inquiry is about.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "inquiry_intervention",
          "label": "Intervention",
          "description": "The exposure, intervention, or phenomenon under study.",
          "input": {
            "type": "text"
          }
        },
        {
          "name": "inquiry_comparison",
          "label": "Comparison",
          "description": "The comparator or contrast case, if any.",
          "input": {
            "type": "text"
          }
        },
        {
          "name": "inquiry_outcome",
          "label": "Outcome",
          "description": "What the inquiry must be able to answer.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "finer_feasible",
          "label": "FINER feasible",
          "description": "Why this project is feasible enough to start.",
          "input": {
            "type": "textarea"
          }
        },
        {
          "name": "finer_novel",
          "label": "FINER novel",
          "description": "What this project could add beyond the current map.",
          "input": {
            "type": "textarea"
          }
        },
        {
          "name": "finer_relevant",
          "label": "FINER relevant",
          "description": "Why the answer matters to the program.",
          "input": {
            "type": "textarea"
          }
        },
        {
          "name": "output_mode",
          "label": "Output mode",
          "description": "Default to thesis-driven; choose survey only when no thesis is appropriate yet.",
          "isRequired": true,
          "input": {
            "type": "select",
            "source": "fixed",
            "options": [
              {
                "label": "Thesis",
                "value": "thesis"
              },
              {
                "label": "Survey",
                "value": "survey"
              }
            ]
          }
        }
      ]
    }
  ]
}
