{
  "editorPosition": "right",
  "attachShortcutToGlobalWindow": false,
  "globalNamespace": "MF",
  "formDefinitions": [
    {
      "title": "Memoria fleeting capture",
      "name": "memoria-fleeting-capture",
      "version": "1",
      "fields": [
        {
          "name": "title",
          "label": "Title",
          "description": "Optional short title.",
          "input": {
            "type": "text"
          }
        },
        {
          "name": "body",
          "label": "Thought, quote, or idea",
          "description": "One raw item per note. Capture first; distill or archive from the Inbox later.",
          "isRequired": true,
          "input": {
            "type": "textarea"
          }
        }
      ]
    },
    {
      "title": "Memoria source capture",
      "name": "memoria-source-capture",
      "version": "1",
      "fields": [
        {
          "name": "title",
          "label": "Source title",
          "description": "Human-readable title for the source note.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "entity",
          "label": "Catalog entity",
          "description": "Catalog record this source note describes.",
          "isRequired": true,
          "input": {
            "type": "note",
            "folder": "catalog"
          }
        },
        {
          "name": "source_type",
          "label": "Source type",
          "description": "Kind of source behind the note.",
          "isRequired": true,
          "input": {
            "type": "select",
            "source": "fixed",
            "options": [
              {
                "label": "Paper",
                "value": "paper"
              },
              {
                "label": "Dataset",
                "value": "dataset"
              },
              {
                "label": "Repository",
                "value": "repository"
              },
              {
                "label": "Web Page",
                "value": "web-page"
              },
              {
                "label": "Report",
                "value": "report"
              }
            ]
          }
        },
        {
          "name": "evidence_level",
          "label": "Evidence level",
          "description": "CEBM-style appraisal grade; use ungraded until appraised.",
          "input": {
            "type": "select",
            "source": "fixed",
            "options": [
              {
                "label": "Cebm 1",
                "value": "cebm-1"
              },
              {
                "label": "Cebm 2",
                "value": "cebm-2"
              },
              {
                "label": "Cebm 3",
                "value": "cebm-3"
              },
              {
                "label": "Cebm 4",
                "value": "cebm-4"
              },
              {
                "label": "Cebm 5",
                "value": "cebm-5"
              },
              {
                "label": "Ungraded",
                "value": "ungraded"
              }
            ]
          }
        },
        {
          "name": "research_area",
          "label": "Research area",
          "description": "What the work is about.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "multi_select_options": [
              "personal-informatics",
              "mobile-health",
              "digital-mental-health",
              "health-equity",
              "patient-clinician-communication",
              "engagement-sustained-use",
              "chronic-disease-management",
              "behavior-change",
              "llm-generative-ai-for-health",
              "patient-generated-data",
              "family-caregiver-health",
              "mobile-sensing",
              "sociotechnical-systems",
              "social-computing-for-health",
              "conversational-agents",
              "community-health",
              "digital-therapeutics",
              "wearable-sensing",
              "aging",
              "human-ai-interaction",
              "online-health-communities",
              "implementation-science",
              "sensemaking",
              "race-intersectionality",
              "cscw-collaborative-work",
              "jitai",
              "ema-self-report"
            ]
          }
        },
        {
          "name": "methodology",
          "label": "Methodology",
          "description": "How the work was structured or analyzed.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "multi_select_options": [
              "rct",
              "clinical-trial",
              "quasi-experiment",
              "observational",
              "field-study",
              "lab-experiment",
              "survey-study",
              "qualitative",
              "design-science",
              "formative-study",
              "case-study",
              "case-report",
              "review",
              "systematic-review",
              "meta-analysis",
              "secondary-analysis",
              "dataset",
              "semi-structured-interview",
              "thematic-analysis",
              "grounded-theory",
              "contextual-inquiry",
              "experience-sampling",
              "ecological-momentary-assessment",
              "diary-study",
              "co-design",
              "usability-testing",
              "think-aloud",
              "survey",
              "regression",
              "mixed-effects-model",
              "log-analysis",
              "machine-learning",
              "nlp",
              "content-analysis",
              "participant-observation",
              "ab-test"
            ]
          }
        },
        {
          "name": "summary",
          "label": "In my words",
          "description": "Short source-grounded summary in your own words.",
          "input": {
            "type": "textarea"
          }
        }
      ]
    },
    {
      "title": "Memoria claim capture",
      "name": "memoria-claim-capture",
      "version": "1",
      "fields": [
        {
          "name": "title",
          "label": "Claim title",
          "description": "Short label for the note and Base row.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "maturity",
          "label": "Maturity",
          "description": "Start at seedling unless the claim is already well supported.",
          "isRequired": true,
          "input": {
            "type": "select",
            "source": "fixed",
            "options": [
              {
                "label": "Seedling",
                "value": "seedling"
              },
              {
                "label": "Budding",
                "value": "budding"
              },
              {
                "label": "Evergreen",
                "value": "evergreen"
              }
            ]
          }
        },
        {
          "name": "sources",
          "label": "Sources",
          "description": "Pick the catalog paper(s) whose citekeys support this claim.",
          "isRequired": true,
          "input": {
            "type": "multiselect",
            "source": "notes",
            "folder": "catalog/papers"
          }
        },
        {
          "name": "topics",
          "label": "Topics",
          "description": "Optional vocabulary tags for retrieval and hub thresholds.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "multi_select_options": [
              "personal-informatics",
              "mobile-health",
              "digital-mental-health",
              "health-equity",
              "patient-clinician-communication",
              "engagement-sustained-use",
              "chronic-disease-management",
              "behavior-change",
              "llm-generative-ai-for-health",
              "patient-generated-data",
              "family-caregiver-health",
              "mobile-sensing",
              "sociotechnical-systems",
              "social-computing-for-health",
              "conversational-agents",
              "community-health",
              "digital-therapeutics",
              "wearable-sensing",
              "aging",
              "human-ai-interaction",
              "online-health-communities",
              "implementation-science",
              "sensemaking",
              "race-intersectionality",
              "cscw-collaborative-work",
              "jitai",
              "ema-self-report"
            ]
          }
        },
        {
          "name": "claim",
          "label": "Claim statement",
          "description": "One durable, source-grounded assertion in your own words.",
          "isRequired": true,
          "input": {
            "type": "textarea"
          }
        }
      ]
    },
    {
      "title": "Memoria project start",
      "name": "memoria-project-start",
      "version": "1",
      "fields": [
        {
          "name": "title",
          "label": "Project title",
          "description": "Bounded research question or working project name.",
          "isRequired": true,
          "input": {
            "type": "text"
          }
        },
        {
          "name": "scope_topics",
          "label": "Scope topics",
          "description": "Controlled vocabulary topics that bound the project.",
          "input": {
            "type": "multiselect",
            "source": "fixed",
            "multi_select_options": [
              "personal-informatics",
              "mobile-health",
              "digital-mental-health",
              "health-equity",
              "patient-clinician-communication",
              "engagement-sustained-use",
              "chronic-disease-management",
              "behavior-change",
              "llm-generative-ai-for-health",
              "patient-generated-data",
              "family-caregiver-health",
              "mobile-sensing",
              "sociotechnical-systems",
              "social-computing-for-health",
              "conversational-agents",
              "community-health",
              "digital-therapeutics",
              "wearable-sensing",
              "aging",
              "human-ai-interaction",
              "online-health-communities",
              "implementation-science",
              "sensemaking",
              "race-intersectionality",
              "cscw-collaborative-work",
              "jitai",
              "ema-self-report"
            ]
          }
        },
        {
          "name": "output_mode",
          "label": "Output mode",
          "description": "Thesis mode starts with a provisional answer; survey mode starts open.",
          "isRequired": true,
          "input": {
            "type": "select",
            "source": "fixed",
            "options": [
              {
                "label": "Thesis",
                "value": "thesis"
              },
              {
                "label": "Survey",
                "value": "survey"
              }
            ]
          }
        },
        {
          "name": "provisional_thesis",
          "label": "Provisional thesis",
          "description": "One-sentence answer under test; shown only for thesis-mode projects.",
          "input": {
            "type": "textarea"
          },
          "condition": {
            "dependencyName": "output_mode",
            "type": "isExactly",
            "value": "thesis"
          }
        }
      ]
    }
  ]
}
