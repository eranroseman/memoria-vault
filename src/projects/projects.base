# Project space — project notes plus generated cache timestamp fields.
filters:
  and:
    - or:
        - file.inFolder("projects")
        - file.inFolder("inbox")
    - 'lifecycle != "archived"'
formulas:
  note: 'link(file.path, title)'
properties:
  formula.note:
    displayName: "Note"
views:
  - type: table
    name: "Active projects"
    filters:
      and:
        - 'type == "project"'
        - 'lifecycle == "current"'
    groupBy:
      property: output_mode
      direction: ASC
    order:
      - formula.note
      - lifecycle
      - output_mode
      - active_thesis
      - refutation_sufficiency
      - argument_stage
      - evidence_saturation
      - computed_at
  - type: table
    name: "Saturation"
    filters:
      and:
        - 'type == "project"'
    groupBy:
      property: evidence_saturation
      direction: ASC
    order:
      - formula.note
      - evidence_saturation
      - argument_stage
      - computed_at
      - active_thesis
  - type: table
    name: "Project gaps"
    filters:
      and:
        - 'type == "gap"'
    groupBy:
      property: gap_type
      direction: ASC
    order:
      - formula.note
      - gap_type
      - impact
      - on_path
      - evidence_saturation
      - argument_stage
