# Claims by maturity and topic (ADR-50: maturity is a property, never a gate).
filters:
  and:
    - file.inFolder("notes/claims")
    - 'lifecycle != "archived"'
formulas:
  note: 'link(file.path, title)'
  is_orphan: 'file.backlinks.isEmpty()'
  age_days: '(now() - file.ctime).days.round(0)'
properties:
  formula.note:
    displayName: "Note"
  formula.is_orphan:
    displayName: "No inbound"
  formula.age_days:
    displayName: "Age (days)"
views:
  - type: table
    name: "By maturity"
    filters:
      not:
        - superseded_by
    groupBy:
      property: maturity
      direction: DESC
    order:
      - formula.note
      - maturity
      - topics
      - sources
  - type: table
    name: "Open questions"
    filters:
      and:
        - 'lifecycle == "current"'
        - formula.is_orphan
    sort:
      - property: file.ctime
        direction: ASC
    order:
      - formula.note
      - topics
      - sources
      - formula.age_days
  - type: table
    name: "Contradictions"
    filters:
      and:
        - 'lifecycle == "current"'
        - '!links.contradicts.isEmpty()'
    sort:
      - property: file.mtime
        direction: DESC
    order:
      - formula.note
      - links
      - topics
  - type: table
    name: "Retracted (lineage)"
    filters:
      and:
        - 'lifecycle == "retracted"'
    order:
      - formula.note
      - superseded_by
      - sources
