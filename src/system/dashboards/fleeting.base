# Fleeting captures — distill or archive (proposed → archived; ADR-50).
filters:
  and:
    - file.inFolder("notes/fleeting")
    - 'file.ext == "md"'
    - 'type == "fleeting"'
views:
  - type: table
    name: "To process"
    filters:
      and:
        - 'lifecycle == "proposed"'
    order:
      - file.name
      - title
      - origin
      - file.ctime
