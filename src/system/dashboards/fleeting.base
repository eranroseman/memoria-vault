# Fleeting captures — distill or archive (proposed → archived; ADR-50).
formulas:
  note: 'link(file.path, title)'
properties:
  formula.note:
    displayName: "Note"
filters:
  and:
    - file.inFolder("notes/fleeting")
    - 'file.ext == "md"'
    - 'type == "fleeting"'
views:
  - type: table
    name: "To process"
    filters:
      and:
        - 'lifecycle == "proposed"'
    order:
      - formula.note
      - origin
      - file.ctime
