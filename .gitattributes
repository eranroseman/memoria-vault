# Line-ending policy.
#
# Memoria is authored on Windows but the Hermes runtime executes on Linux/WSL2.
# Shell scripts and runtime config MUST be LF: a CRLF in install.sh breaks the
# WSL2 shebang (`bad interpreter: bash^M`), and a CRLF inside a YAML/JSON value
# can inject a stray \r into substituted paths. Pin them to LF on every OS,
# independent of the local core.autocrlf setting.

# Default: let Git decide text vs binary, normalize to LF in the repo.
* text=auto

# Runtime / executable files — always LF on checkout, every platform.
*.sh    text eol=lf
*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.bib   text eol=lf
*.canvas text eol=lf

# Windows launcher — PowerShell is fine with either, keep CRLF to match the OS.
*.ps1   text eol=crlf

# Binaries — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
