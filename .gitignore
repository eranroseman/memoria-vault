# Python bytecode, caches, and editable-install metadata
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.nox/
.venv/
*.egg-info/

# Claude Code local worktrees (per-branch checkouts; never part of the repo)
.claude/worktrees/

# qmd local semantic-search index (per-machine; absolute paths in index.yml)
/.qmd/

# Node deps for the repo-local qmd code-search engine (devDependency; pinned via package-lock.json)
/node_modules/

# Jekyll build artifacts (published via GitHub Pages from /docs)
docs/_site/
docs/.jekyll-cache/

# Vault-internal secrets and per-machine files are gitignored in vault/.gitignore
# (alongside the existing REST-API / workspace / .env entries).
.coverage

# OS noise (root-level catches; vault/.gitignore handles vault subtree)
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~


# Scratch / per-machine working state, never committed. Root-anchored where it
# could shadow tracked paths (docs/_config.yml etc. stay tracked).
/.notes/
TODO*

# Per-branch worktrees and the disposable installed sandbox vault (its own nested
# .git; always reconstructible — never source of truth).
.worktrees/
/sandbox/

# Local tool + harness state at the repo root, never committed.
.kilo/
claude-plans/
