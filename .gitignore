# Python bytecode (docs-doctor + profile scripts)
__pycache__/
*.pyc

# ---------------------------------------------------------------------------
# Files holding private / per-machine data. Each is gitignored and ships as a
# sanitized example (.example / .EXAMPLE) that you copy and fill in locally.
# Keep this list and the example files in sync: a new secret-bearing file gets
# BOTH a gitignore line here AND an example sibling.
# ---------------------------------------------------------------------------

# Local REST API: holds the generated apiKey, a TLS cert, and an RSA private
# key. Regenerated by the plugin on first launch. → data.json.example
vault/.obsidian/plugins/obsidian-local-rest-api/data.json

# agent-client: holds per-machine agent command paths (absolute {{HOME}} paths)
# and any provider apiKeys. → data.json.example
vault/.obsidian/plugins/agent-client/data.json

# Librarian project hints: your personal project scopes and topic lists (ADR-30).
# → project-hints.yaml.EXAMPLE
vault/.memoria/project-hints.yaml

# Environment files holding the Hermes API key etc. (anticipated by setup docs).
# Keep .env.example committable. → .env.example
.env
.env.*
!.env.example
