# Python bytecode (docs-doctor + profile scripts)
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.nox/
.venv/

# Claude Code local worktrees (per-branch checkouts; never part of the repo)
.claude/worktrees/
/.worktrees/

# qmd local semantic-search index (per-machine; absolute paths in index.yml)
/.qmd/

# Jekyll build artifacts (published via GitHub Pages from /docs)
docs/_site/
docs/.jekyll-cache/

# Vault-internal secrets and per-machine files are gitignored in vault/.gitignore
# (alongside the existing REST-API / workspace / .env entries).
.coverage

# OS noise (root-level catches; vault/.gitignore handles vault subtree)
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~


# Scratch at repo root — underscore-prefixed working dirs/files, never committed.
# Root-anchored (leading /) and listed explicitly, NOT a `_*` glob: docs/_config.yml
# (Jekyll) and other docs/_* files must stay tracked.
/_notes/
/_papers/
