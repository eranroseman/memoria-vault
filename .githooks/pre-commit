#!/bin/sh
# Memoria pre-commit guard — a fast local mirror of the required CI checks, so
# failures surface before push/PR instead of in GitHub Actions.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Each block runs ONLY when relevant files are staged (so unrelated commits stay
# fast). Bypass any block (rarely) with:  git commit --no-verify
#
# Mirrors the CI checks: docs-doctor, shellcheck (install.sh), PSScriptAnalyzer
# (install.ps1 — CI only; not run here), python-selftest, ruff, check-test-refs,
# dashboard schema-drift, yamllint, JSON syntax, markdownlint structural.

fail=0
staged() { git diff --cached --name-only; }
PY=$(command -v python || command -v python3 || true)

# --- 0. Warn on a direct commit to main -------------------------------------
# main is PR-protected upstream; committing here usually means you forgot to
# branch (and an editor auto-backup can sweep work into main). Warn, don't block.
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
if [ "$branch" = "main" ]; then
  echo "pre-commit: WARNING - committing on 'main'. main is PR-protected; you" >&2
  echo "            probably want a branch:  git switch -c fix/<thing>" >&2
fi

# --- 1. docs-doctor (when docs/ or the linter is staged) --------------------
if staged | grep -qE '^docs/|^scripts/docs-doctor\.py'; then
  if [ -n "$PY" ]; then
    "$PY" scripts/docs-doctor.py docs || { echo "pre-commit: docs-doctor failed (above)." >&2; fail=1; }
  else
    echo "pre-commit: python not found; skipping docs-doctor" >&2
  fi
fi

# --- 2. install.sh parse + shellcheck (when install.sh is staged) -----------
if staged | grep -qE '^install\.sh$'; then
  bash -n install.sh || { echo "pre-commit: install.sh has a syntax error." >&2; fail=1; }
  if command -v shellcheck >/dev/null 2>&1; then
    shellcheck -S warning install.sh || { echo "pre-commit: shellcheck found issues." >&2; fail=1; }
  fi
fi

# --- 3. Python --self-test (when any tracked .py tool is staged) ------------
if staged | grep -qE '\.py$'; then
  if [ -n "$PY" ]; then
    P=vault/.memoria
    for t in "$P/mcp/policy_mcp.py" "$P/mcp/policy_hook.py" "$P/mcp/board_export.py" \
             "$P/mcp/metrics_aggregate.py" "$P/mcp/verify_mcp.py" \
             "$P/profiles/memoria-linter/skills/structural-detectors/scripts/detectors.py"; do
      [ -f "$t" ] || continue
      "$PY" "$t" --self-test >/dev/null 2>&1 || { echo "pre-commit: self-test FAILED: $t" >&2; fail=1; }
    done
  else
    echo "pre-commit: python not found; skipping self-tests" >&2
  fi
  # ruff lint over the Python tooling (mirrors the `ruff` CI job; config in ruff.toml).
  if command -v ruff >/dev/null 2>&1; then
    ruff check scripts vault/.memoria || { echo "pre-commit: ruff found issues (above)." >&2; fail=1; }
  else
    echo "pre-commit: ruff not installed; skipping (CI enforces it)" >&2
  fi
fi

# --- 4. docs/ reference resolution (staged .md / .py / .yaml) ----------------
# vault/ ships WITHOUT the docs/ tree, so vault files reference Memoria's docs
# only via absolute GitHub Pages URLs — and those, plus any bare docs/<path>.md a
# file names (e.g. a drift-detector's input), must resolve to a real file. This
# catches stale filenames before they ship. External Hermes docs (the
# nousresearch.com host) carry no `.md` and are skipped.
for f in $(staged | grep -E '\.(md|py|ya?ml)$'); do
  [ -f "$f" ] || continue
  # 4a. bare repo-relative docs/<path>.md must exist
  for ref in $(grep -oE 'docs/[A-Za-z0-9/_.-]+\.md' "$f" | sort -u); do
    [ -f "$ref" ] || { echo "pre-commit: $f -> missing $ref" >&2; fail=1; }
  done
  # 4b. GitHub Pages URL must map to a real docs file (strip #anchor, trailing /)
  for url in $(grep -oE 'https://eranroseman\.github\.io/memoria-vault/[A-Za-z0-9/_-]+' "$f" | sort -u); do
    rel=${url#https://eranroseman.github.io/memoria-vault/}; rel=${rel%/}
    [ -f "docs/$rel.md" ] || [ -f "docs/$rel/index.md" ] || [ -f "docs/$rel/README.md" ] \
      || { echo "pre-commit: $f -> Pages URL with no docs target: $url" >&2; fail=1; }
  done
  # 4c. github blob URLs for docs/ are banned — convention is Pages URLs only
  if grep -q 'github.com/eranroseman/memoria-vault/blob/main/docs/' "$f"; then
    echo "pre-commit: $f uses a github blob URL for docs/ — use the Pages URL instead" >&2; fail=1
  fi
done

# --- 5. test-plan reference resolution (staged test plans) ------------------
# The plans under docs/testing/ name many repo paths; check-test-refs ensures
# each resolves, so a rename can't leave a plan pointing at a dead file.
# Mirrors the check-test-refs CI job.
if staged | grep -qE '^docs/testing/.*\.md$|^scripts/check-test-refs\.py$'; then
  if [ -n "$PY" ]; then
    "$PY" scripts/check-test-refs.py || { echo "pre-commit: check-test-refs failed (above)." >&2; fail=1; }
  else
    echo "pre-commit: python not found; skipping check-test-refs" >&2
  fi
fi

# --- 6. dashboard schema-drift (when a dashboard or template is staged) ------
# A dashboard querying a field no template emits is a silent empty table. Only
# these two folders can introduce that drift, so the (whole-vault) scan runs
# only when one is staged — keeping the hook per-diff. dashboard-field-drift
# blocks; other vault findings stay advisory. Mirrors the gated CI step.
if staged | grep -qE '^vault/00-meta/01-dashboards/.*\.md$|^vault/99-system/templates/.*\.md$'; then
  if [ -n "$PY" ]; then
    "$PY" vault/.memoria/profiles/memoria-linter/skills/structural-detectors/scripts/detectors.py --vault vault --gate dashboard-field-drift \
      || { echo "pre-commit: dashboard schema-drift (above)." >&2; fail=1; }
  else
    echo "pre-commit: python not found; skipping schema-drift" >&2
  fi
fi

# --- 7. yamllint (when a staged YAML is not under vault/.obsidian) ----------
# Profile config / lane-override / cron / workflow YAML is load-bearing. Lints
# only the staged, non-.obsidian YAML (vault/.obsidian is vendored); uses
# .yamllint. Mirrors the lint-config CI job. Skipped with a notice if absent.
yml_staged=$(staged | grep -E '\.ya?ml$' | grep -v 'vault/\.obsidian/')
if [ -n "$yml_staged" ]; then
  if command -v yamllint >/dev/null 2>&1; then
    echo "$yml_staged" | xargs -r yamllint || { echo "pre-commit: yamllint found issues (above)." >&2; fail=1; }
  else
    echo "pre-commit: yamllint not installed; skipping (CI enforces it)" >&2
  fi
fi

# --- 8. JSON syntax (when an authored .json is staged) ----------------------
if staged | grep -E '\.json$' | grep -qv '.obsidian/plugins/'; then
  if [ -n "$PY" ]; then
    for f in $(staged | grep -E '\.json$' | grep -v '.obsidian/plugins/'); do
      [ -f "$f" ] || continue
      "$PY" -m json.tool "$f" >/dev/null || { echo "pre-commit: invalid JSON: $f" >&2; fail=1; }
    done
  fi
fi

# --- 9. markdownlint structural rules (when a docs/ .md is staged) ----------
# Mirrors the markdownlint CI job (MD011/039/042/056/058 — real rendering bugs).
if staged | grep -qE '^docs/.*\.md$'; then
  if command -v npx >/dev/null 2>&1; then
    npx --yes markdownlint-cli@0.42.0 --config .github/markdownlint/docs-structural.json 'docs/**/*.md' \
      || { echo "pre-commit: markdownlint structural rules failed (above)." >&2; fail=1; }
  else
    echo "pre-commit: npx not found; skipping markdownlint (CI enforces it)" >&2
  fi
fi

# --- 10. ADR index current (when an ADR or the generator is staged) ---------
# The ADR table in docs/adr/README.md is generated from each ADR's frontmatter;
# a new/renamed/superseded ADR leaves it stale. Mirrors the python-selftest gate.
if staged | grep -qE '^docs/adr/.*\.md$|^scripts/gen-adr-index\.py$'; then
  if [ -n "$PY" ]; then
    "$PY" scripts/gen-adr-index.py --check \
      || { echo "pre-commit: ADR index stale — run: python scripts/gen-adr-index.py" >&2; fail=1; }
  else
    echo "pre-commit: python not found; skipping ADR index check" >&2
  fi
fi

# --- 11. status-doctor (when any docs/ release/test/contributing doc or the /release skill is staged) --
# The docs/ release+test+contributing prose (+ the /release skill) is prose +
# pointers; this guards stale path renames, broken links, and released-flag
# drift. Mirrors the status-doctor step in the lint CI job.
if staged | grep -qE '^docs/(releasing|testing|contributing)/.*\.md$|^\.claude/skills/release/SKILL\.md$|^scripts/status-doctor\.py$'; then
  if [ -n "$PY" ]; then
    "$PY" scripts/status-doctor.py || { echo "pre-commit: status-doctor found project-doc drift (above)." >&2; fail=1; }
  else
    echo "pre-commit: python not found; skipping status-doctor" >&2
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "pre-commit: blocked. Fix the above, or bypass with: git commit --no-verify" >&2
  exit 1
fi
exit 0
