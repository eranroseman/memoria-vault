{
  "search.exclude": {
    "**/_site/**": true,
    "docs/_site/**": true,
    "docs/.jekyll-cache/**": true,
    "_reports/**": true,
    "_notes/**": true,
    "_papers/**": true
  },
  "files.watcherExclude": {
    "**/_site/**": true,
    "docs/_site/**": true,
    "_papers/**": true,
    "_notes/**": true,
    "_reports/**": true,
    "docs/.jekyll-cache/**": true
  },
  "shellcheck.customArgs": ["--severity=warning"],
  "powershell.scriptAnalysis.enable": true,
  "powershell.scriptAnalysis.settingsPath": "scripts/PSScriptAnalyzerSettings.psd1",
  "linter.linters": {
    "yamllint": {
      "enabled": true
    }
  },
  "markdownlint.enable": true,
  "markdownlint.config": {
    "extends": ".markdownlint.json",
    "MD013": {
      "line_length": 90,
      "headings": false,
      "code_blocks": false,
      "tables": false
    }
  },
  "harper.enabled": true,
  "harper.diagnosticsOnChange": false,
  "harper.enabledRules": {
    "SpellCheck": false
  },
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    }
  },
  "[plaintext]": {
    "editor.formatOnSave": false
  },
  "[python]": {
    "editor.formatOnSave": false,
    "harper.enabled": false
  },
  "[yaml]": {
    "harper.enabled": false
  },
  "[shellscript]": {
    "harper.enabled": false
  },
  "cSpell.ignorePaths": [
    "docs/reference/bibliography.md",
    "src/.obsidian/**",
    "_papers/**",
    "**/_site/**",
    "docs/.jekyll-cache/**"
  ],
  "cSpell.customDictionaries": {
    "memoria-project": {
      "name": "memoria-project",
      "path": "${workspaceFolder}/.cspell/project-words.txt",
      "scope": "workspace",
      "addWords": true
    }
  },
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true
}
