{
  "search.exclude": {
    "**/_site/**": true,
    "docs/_site/**": true,
    "docs/.jekyll-cache/**": true,
    "_reports/**": true,
    "_notes/**": true,
    "_papers/**": true
  },
  "files.watcherExclude": {
    "**/_site/**": true,
    "docs/_site/**": true,
    "_papers/**": true
  },
  "shellcheck.customArgs": ["--severity=warning"],
  "powershell.scriptAnalysis.enable": true,
  "powershell.scriptAnalysis.settingsPath": "scripts/PSScriptAnalyzerSettings.psd1",
  "linter.linters": {
    "yamllint": {
      "enabled": true
    }
  },
  "harper.enabled": true,
  "harper.diagnosticSeverity": "hint",
  "harper.diagnosticsOnChange": false,
  "harper.enabledRules": {
    "SpellCheck": false
  },
  "[markdown]": {
    "harper.enabled": true,
    "editor.formatOnSave": false
  },
  "[plaintext]": {
    "harper.enabled": true,
    "editor.formatOnSave": false
  },
  "[python]": {
    "editor.formatOnSave": false,
    "harper.enabled": false
  },
  "[yaml]": {
    "harper.enabled": false
  },
  "[shellscript]": {
    "harper.enabled": false
  },
  "cSpell.ignorePaths": [
    "docs/reference/bibliography.md",
    "vault/.obsidian/**",
    "_papers/**",
    "_notes/**",
    "_reports/**",
    "**/_site/**",
    "docs/.jekyll-cache/**"
  ],
