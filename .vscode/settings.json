{
  "search.exclude": {
    "**/_site/**": true,
    "docs/_site/**": true,
    "docs/.jekyll-cache/**": true,
    "_reports/**": true,
    "_notes/**": true,
    "_papers/**": true
  },
  "files.watcherExclude": {
    "**/_site/**": true,
    "docs/_site/**": true,
    "_papers/**": true,
    "_notes/**": true,
    "_reports/**": true,
    "docs/.jekyll-cache/**": true
  },
  "shellcheck.customArgs": ["--severity=warning"],
  "powershell.scriptAnalysis.enable": true,
  "powershell.scriptAnalysis.settingsPath": "scripts/PSScriptAnalyzerSettings.psd1",
  "linter.linters": {
    "yamllint": {
      "enabled": true
    }
  },
  "markdownlint.enable": true,
  "markdownlint.config": {
    "extends": ".markdownlint.json",
    "MD013": {
      "line_length": 90,
      "headings": false,
      "code_blocks": false,
      "tables": false
    }
  },
  "harper.linters.SpellCheck": false,
  "harper.linters.UseTitleCase": false,
  "harper.linters.SplitWords": false,
  "harper.excludePatterns": ["**/*.py", "**/*.yml", "**/*.yaml", "**/*.sh"],
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    }
  },
  "[plaintext]": {
    "editor.formatOnSave": false
  },
  "[python]": {
    "editor.formatOnSave": false
  },
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true
}
