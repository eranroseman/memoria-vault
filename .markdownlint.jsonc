{
    "MD013": false,
    "MD024": false,
    // ADRs intentionally carry a YAML `title:` field and an `# ADR-NN` H1;
    // don't treat the front-matter title as the document's single H1.
    "MD025": { "front_matter_title": "" },
    "MD036": false,
    "MD055": false,
    // MD056 (table column count) stays ON: a row with the wrong number of
    // cells is a real broken-table bug, not a style nit — keep it enabled.
    "MD060": false
}
