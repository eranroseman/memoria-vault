{
  "_comment": "Example agent-client config. Replace {{...}} placeholders with absolute paths on your machine before copying to vault/.obsidian/plugins/agent-client/data.json. After first launch, the plugin appends savedSessions[] — that's normal and safe to commit. See memoria-docs/references/obsidian-plugins.md#agent-client.",

  "_customAgents_note": "Memoria configures four interactive agents in the picker, labeled by identity (not action): Socratic (default — persistent thinking chat), Mapper (transient corpus queries), Writer (distill + drafting), Verifier (transient cite/similarity check). The three batch profiles — Librarian, Coder, Linter — are intentionally absent; they run via Kanban dispatch or cron, not interactive ACP chat. On secondary devices that don't have all four profiles installed, delete the entries for profiles not installed. See memoria-docs/plugins/required/agent-client.md for per-profile rationale and the mode-switching hotkey conventions.",

  "claude": {
    "id": "claude-code-acp",
    "displayName": "Claude Code",
    "apiKey": "",
    "command": "{{HOME}}/.hermes/node/bin/claude-agent-acp",
    "args": [],
    "env": []
  },
  "codex": {
    "id": "codex-acp",
    "displayName": "Codex",
    "apiKey": "",
    "command": "codex-acp",
    "args": [],
    "env": []
  },
  "gemini": {
    "id": "gemini-cli",
    "displayName": "Gemini CLI",
    "apiKey": "",
    "command": "gemini",
    "args": ["--experimental-acp"],
    "env": []
  },
  "customAgents": [
    {
      "id": "memoria-socratic",
      "displayName": "Socratic — Think a source through in conversation before you distill it.",
      "command": "{{HOME}}/.local/bin/hermes",
      "args": ["-p", "memoria-socratic", "acp"],
      "env": []
    },
    {
      "id": "memoria-mapper",
      "displayName": "Mapper — Map a project's corpus — what's ready, thin, missing — before writing.",
      "command": "{{HOME}}/.local/bin/hermes",
      "args": ["-p", "memoria-mapper", "acp"],
      "env": []
    },
    {
      "id": "memoria-writer",
      "displayName": "Writer — Distill sources into claim notes; turn framings into drafts.",
      "command": "{{HOME}}/.local/bin/hermes",
      "args": ["-p", "memoria-writer", "acp"],
      "env": []
    },
    {
      "id": "memoria-verifier",
      "displayName": "Verifier — Trace a draft's claims back to their sources; flag the gaps.",
      "command": "{{HOME}}/.local/bin/hermes",
      "args": ["-p", "memoria-verifier", "acp"],
      "env": []
    }
  ],

  "defaultAgentId": "memoria-socratic",
  "autoAllowPermissions": false,
  "autoMentionActiveNote": true,
  "enableSystemNotifications": true,
  "debugMode": false,
  "nodePath": "",

  "exportSettings": {
    "defaultFolder": "10-inbox/02-answers",
    "filenameTemplate": "agent_client_{date}_{time}",
    "autoExportOnNewChat": false,
    "autoExportOnCloseChat": false,
    "openFileAfterExport": true,
    "includeImages": true,
    "imageLocation": "obsidian",
    "imageCustomFolder": "90-assets",
    "frontmatterTag": "agent-client"
  },

  "_wsl_note": "Set windowsWslMode: true if the agent commands above resolve through WSL on Windows. The plugin will translate Windows paths to /mnt/c/... format for the subprocess.",
  "windowsWslMode": false,

  "sendMessageShortcut": "enter",
  "chatViewLocation": "right-tab",

  "displaySettings": {
    "autoCollapseDiffs": false,
    "diffCollapseThreshold": 10,
    "maxNoteLength": 10000,
    "maxSelectionLength": 10000,
    "showEmojis": true,
    "fontSize": null
  },

  "_savedSessions_note": "Populated by the plugin as you use ACP. Human-generated state; safe to commit but periodically prune to keep data.json small. Sessions accumulate primarily from Socratic (persistent processing chats); Mapper / Writer / Verifier sessions are transient and they are usually cleared automatically.",
  "savedSessions": [],

  "lastUsedModels": {},
  "lastUsedModes": {},
  "enableFloatingChat": false,
  "floatingButtonImage": "",
  "floatingWindowSize": {"width": 400, "height": 500},
  "floatingWindowPosition": null,
  "floatingButtonPosition": null
}
