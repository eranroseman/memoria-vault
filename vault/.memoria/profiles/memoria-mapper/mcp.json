{
  "mcp_servers": {
    "policy": {
      "command": "python",
      "args": [
        "{{VAULT_PATH}}/.memoria/mcp/policy_mcp.py",
        "--vault",
        "{{VAULT_PATH}}"
      ],
      "enabled": true,
      "timeout": 30
    },
    "obsidian": {
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "enabled": true,
      "timeout": 30,
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      }
    }
  }
}
