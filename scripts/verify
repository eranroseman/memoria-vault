#!/usr/bin/env python3
"""Run Memoria's single verification gate.

One flat gate, no tiers: lint (the pinned manual-stage pre-commit hooks), the
product-integrity checks, the test suite, an offline end-to-end smoke, and
syntax checks. Runs the roster in order, prints each step, skips (does not
fail) a check whose local tool is absent (e.g. PowerShell), and exits nonzero
on the first hard failure.

Docs-only narrowing (CI only): when `VERIFY_DOCS_ONLY=1`, the roster drops the
gates a docs-only diff (`*.md` / `design-history/`) provably cannot affect —
the unit/contract tests, the e2e smoke, `compileall`, `bash -n`, and the
JSON/PowerShell syntax checks — and narrows pytest to the `static` marker
(schema, docs-refs, design-history, spell). CI sets this only for PRs whose
whole diff is documentation; local runs and the post-merge `main` run always
execute the full roster.
"""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]

# CI sets this to "1" only for provably docs-only PRs (see the module docstring).
DOCS_ONLY = os.environ.get("VERIFY_DOCS_ONLY") == "1"

# Source of truth for what "verified" means; tests/test_verify_script.py mirrors
# this roster. Lint runs the manual-stage pre-commit hooks (ruff, ruff-format,
# yamllint, shellcheck, cspell, markdownlint); the commit-stage hooks
# (gitleaks, no-commit-to-branch) are pinned out of the manual stage so this
# never trips no-commit-to-branch on the post-merge main run.
GATES: list[list[str]] = [
    ["pre-commit", "run", "--hook-stage", "manual", "--all-files"],
    ["python3", "scripts/checks/schema_doc_drift.py"],
    ["python3", "scripts/checks/removed_surface_gate.py"],
    ["python3", "scripts/checks/checked_terminology_gate.py"],
    ["python3", "scripts/checks/plugin_provenance_doctor.py"],
    [
        "env",
        "PYTEST_DISABLE_PLUGIN_AUTOLOAD=1",
        "python3",
        "-m",
        "pytest",
        "tests/",
        "-q",
        "-m",
        "static or unit or contract",
    ],
    ["python3", "scripts/test_vault/e2e_smoke.py"],
    [
        "python3",
        "-m",
        "compileall",
        "-q",
        "src/memoria_vault",
        "scripts/checks",
        "scripts/test_vault",
        "scripts/verify",
    ],
    [
        "bash",
        "-n",
        "scripts/install.sh",
        "scripts/test_vault/refresh-test-vault.sh",
        "scripts/test_vault/install-test-vault-local-llm.sh",
    ],
]

# Self-skips when the analyzer module is absent (exit 2), so a machine with pwsh
# but no PSScriptAnalyzer does not hard-fail the gate.
PSSA_COMMAND = (
    "if (-not (Get-Module -ListAvailable -Name PSScriptAnalyzer)) "
    "{ Write-Host 'PSScriptAnalyzer module not installed'; exit 2 }; "
    "$r = Invoke-ScriptAnalyzer -Path scripts/install.ps1 -Severity Warning,Error "
    "-Settings ./scripts/PSScriptAnalyzerSettings.psd1; "
    "if ($r) { $r | Format-Table -AutoSize; exit 1 }"
)


# Gates a docs-only diff cannot affect: they exercise code, not documentation.
_DOCS_SKIP = ("e2e_smoke.py", "-m compileall", "bash -n")


def _gates_for_run(docs_only: bool) -> list[list[str]]:
    """The full roster, or its docs-relevant subset when docs_only is set."""
    if not docs_only:
        return GATES
    reduced: list[list[str]] = []
    for command in GATES:
        joined = " ".join(command)
        if any(marker in joined for marker in _DOCS_SKIP):
            continue
        if "pytest" in joined:
            command = ["static" if arg == "static or unit or contract" else arg for arg in command]
        reduced.append(command)
    return reduced


def run(command: list[str]) -> int:
    print(f"== {' '.join(command)}")
    return subprocess.run(command, cwd=ROOT, check=False).returncode


def check_json() -> int:
    listing = subprocess.run(
        ["git", "ls-files", "*.json"],
        cwd=ROOT,
        text=True,
        capture_output=True,
        check=False,
    )
    bad: list[str] = []
    for name in listing.stdout.split():
        try:
            json.loads((ROOT / name).read_text(encoding="utf-8"))
        except (ValueError, OSError) as exc:
            bad.append(f"{name}: {exc}")
    print("== authored JSON syntax")
    for entry in bad:
        print(f"  invalid JSON: {entry}")
    return 1 if bad else 0


def check_powershell() -> int:
    print("== PSScriptAnalyzer scripts/install.ps1")
    if shutil.which("pwsh") is None:
        print("  skipped: pwsh not installed")
        return 0
    code = subprocess.run(
        ["pwsh", "-NoProfile", "-Command", PSSA_COMMAND],
        cwd=ROOT,
        check=False,
    ).returncode
    if code == 2:
        print("  skipped: PSScriptAnalyzer module not installed")
        return 0
    return code


def main() -> int:
    if DOCS_ONLY:
        print("== verify: docs-only scope — lint, product gates, and static tests only")
    for command in _gates_for_run(DOCS_ONLY):
        if run(command) != 0:
            print("verify: FAILED", file=sys.stderr)
            return 1
    # The JSON and PowerShell syntax checks test code/config, not documentation.
    extra_steps = () if DOCS_ONLY else (check_json, check_powershell)
    for step in extra_steps:
        if step() != 0:
            print("verify: FAILED", file=sys.stderr)
            return 1
    print("verify: OK")
    return 0


if __name__ == "__main__":
    sys.exit(main())
