#!/usr/bin/env python3
"""Run Memoria verification gates and write a small evidence bundle."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import platform
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
import time
import tomllib
from datetime import UTC, datetime
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]

GATE_COMMANDS = {
    "source": [["bash", "scripts/test.sh", "source"]],
    "package": [
        [
            "python3",
            "-m",
            "pip",
            "wheel",
            "--no-build-isolation",
            "--wheel-dir",
            "{evidence_dir}/dist",
            ".",
        ],
        ["python3", "-m", "venv", "--clear", "{evidence_dir}/venv"],
        [
            "{evidence_dir}/venv/bin/python",
            "-m",
            "pip",
            "install",
            "--force-reinstall",
            "--no-index",
            "--find-links",
            "{evidence_dir}/dist",
            "memoria-vault",
        ],
        [
            "{evidence_dir}/venv/bin/python",
            "-c",
            "import memoria_vault; print(memoria_vault.__version__)",
        ],
        ["bash", "scripts/e2e-smoke.sh"],
    ],
    "runtime": [
        ["python3", "-m", "pytest", "tests/test_alpha15_runtime_gate.py", "-q"],
        ["python3", "-m", "pytest", "tests/test_alpha11_cycle.py", "-q"],
        [
            "python3",
            "-m",
            "pytest",
            "tests/test_cli.py",
            "tests/test_seeded_errors.py",
            "tests/test_worker_queue.py",
            "-q",
        ],
    ],
    "live": [["bash", "scripts/test.sh", "live"]],
}

MODES = {
    "pr": ["source"],
    "package": ["source", "package"],
    "runtime": ["source", "package", "runtime"],
    "rc": ["source", "package", "runtime"],
    "live": ["runtime", "live"],
}

MANUAL_FOLLOW_UP = {
    "rc": [
        "Complete product/manual release evidence in the release parent issue.",
        "Follow .agents/playbooks/release.md for release cut checks.",
    ],
    "live": [
        "Complete runtime/product manual checks from .agents/playbooks/verify-change.md.",
    ],
}


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("mode", choices=sorted(MODES), help="verification gate set to run")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="write evidence and print commands without running them",
    )
    parser.add_argument(
        "--evidence-dir",
        type=Path,
        help="directory for summary.json and command logs; defaults under /tmp",
    )
    return parser.parse_args()


def git_output(*args: str) -> str:
    result = subprocess.run(
        ["git", *args],
        cwd=ROOT,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return result.stdout.strip() if result.returncode == 0 else "unknown"


def hermes_version() -> str:
    if shutil.which("hermes") is None:
        return "not-found"
    for command in (["hermes", "--version"], ["hermes", "version"]):
        result = subprocess.run(
            command,
            cwd=ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            check=False,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip().splitlines()[0]
    return "unknown"


def package_versions() -> dict[str, str]:
    versions: dict[str, str] = {}
    pyproject = ROOT / "pyproject.toml"
    if pyproject.exists():
        data = tomllib.loads(pyproject.read_text(encoding="utf-8"))
        versions["pyproject"] = str(data.get("project", {}).get("version", "unknown"))
    init_file = ROOT / "src" / "memoria_vault" / "__init__.py"
    if init_file.exists():
        match = re.search(r'^__version__ = "([^"]+)"', init_file.read_text(encoding="utf-8"), re.M)
        versions["package_init"] = match.group(1) if match else "unknown"
    return versions


def artifact_hashes(evidence_dir: Path) -> list[dict[str, object]]:
    dist = evidence_dir / "dist"
    if not dist.exists():
        return []
    artifacts: list[dict[str, object]] = []
    for path in sorted(p for p in dist.iterdir() if p.is_file()):
        digest = hashlib.sha256(path.read_bytes()).hexdigest()
        artifacts.append({"file": str(path), "bytes": path.stat().st_size, "sha256": digest})
    return artifacts


def cleanup_package_build_artifacts() -> None:
    for rel in ("build", "src/memoria_vault.egg-info"):
        path = ROOT / rel
        if path.is_dir():
            shutil.rmtree(path)


def prepare_package_evidence(evidence_dir: Path) -> None:
    for rel in ("dist", "venv"):
        path = evidence_dir / rel
        if path.is_dir():
            shutil.rmtree(path)
        elif path.exists():
            path.unlink()


def default_evidence_dir(mode: str, timestamp: str) -> Path:
    default_base = Path(tempfile.gettempdir()) / "memoria-verify"
    base = Path(os.environ.get("MEMORIA_VERIFY_EVIDENCE_DIR", str(default_base)))
    return base / f"{timestamp}-{mode}"


def write_summary(evidence_dir: Path, summary: dict[str, object]) -> None:
    evidence_dir.mkdir(parents=True, exist_ok=True)
    (evidence_dir / "summary.json").write_text(
        json.dumps(summary, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )


def run_step(
    gate: str,
    index: int,
    command_template: list[str],
    evidence_dir: Path,
    dry_run: bool,
) -> dict[str, object]:
    started = time.monotonic()
    command = [part.format(evidence_dir=str(evidence_dir)) for part in command_template]
    display = shlex.join(command)
    log_path = evidence_dir / f"{index:02d}-{gate}.log"
    print(f"== {gate}: {display}")
    if dry_run:
        log_path.write_text(display + "\n", encoding="utf-8")
        return {
            "gate": gate,
            "command": command,
            "display": display,
            "returncode": 0,
            "result": "dry-run",
            "duration_seconds": 0,
            "log": str(log_path),
        }

    result = subprocess.run(
        command,
        cwd=ROOT,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    log_path.write_text(result.stdout, encoding="utf-8")
    print(result.stdout, end="")
    status = (
        "passed" if result.returncode == 0 else "skipped" if result.returncode == 77 else "failed"
    )
    return {
        "gate": gate,
        "command": command,
        "display": display,
        "returncode": result.returncode,
        "result": status,
        "duration_seconds": round(time.monotonic() - started, 3),
        "log": str(log_path),
    }


def main() -> int:
    args = parse_args()
    timestamp = datetime.now(UTC).strftime("%Y%m%dT%H%M%SZ")
    evidence_dir = args.evidence_dir or default_evidence_dir(args.mode, timestamp)
    evidence_dir.mkdir(parents=True, exist_ok=True)
    if "package" in MODES[args.mode]:
        prepare_package_evidence(evidence_dir)

    summary: dict[str, object] = {
        "mode": args.mode,
        "timestamp_utc": timestamp,
        "result": "running",
        "exit_code": None,
        "repo": {
            "branch": git_output("branch", "--show-current"),
            "commit": git_output("rev-parse", "HEAD"),
            "dirty": bool(git_output("status", "--short")),
        },
        "host": {
            "platform": platform.platform(),
            "python": platform.python_version(),
            "hermes": hermes_version(),
        },
        "versions": package_versions(),
        "artifacts": [],
        "gates": MODES[args.mode],
        "steps": [],
        "manual_follow_up": MANUAL_FOLLOW_UP.get(args.mode, []),
    }
    write_summary(evidence_dir, summary)

    exit_code = 0
    steps: list[dict[str, object]] = []
    step_index = 1
    for gate in MODES[args.mode]:
        for command in GATE_COMMANDS[gate]:
            step = run_step(gate, step_index, command, evidence_dir, args.dry_run)
            steps.append(step)
            step_index += 1
            if step["returncode"] != 0:
                exit_code = int(step["returncode"])
                break
        if exit_code:
            break

    if args.dry_run:
        result = "dry-run"
    elif exit_code == 0:
        result = "passed"
    elif exit_code == 77:
        result = "skipped"
    else:
        result = "failed"

    if not args.dry_run and "package" in MODES[args.mode]:
        cleanup_package_build_artifacts()

    summary["steps"] = steps
    summary["artifacts"] = artifact_hashes(evidence_dir)
    summary["result"] = result
    summary["exit_code"] = exit_code
    write_summary(evidence_dir, summary)

    print(f"Evidence: {evidence_dir / 'summary.json'}")
    if summary["manual_follow_up"]:
        print("Manual follow-up:")
        for item in summary["manual_follow_up"]:
            print(f"- {item}")
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
