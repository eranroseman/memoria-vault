{
  "version": "0.2",
  "language": "en",
  "enableGlobDot": true,
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "project-words"
  ],
  "files": [
    "**/*.md"
  ],
  "ignorePaths": [
    "docs/reference/evidence-and-integrations/bibliography.md",
    "docs/superpowers/**",
    ".notes/**",
    "scratch/**",
    "**/tmp/**",
    "**/_site/**",
    "docs/.jekyll-cache/**",
    "**/*.lock",
    "**/package-lock.json",
    "project-words.txt"
  ],
  "words": [
    "Docstrings",
    "pydocstyle"
  ]
}
